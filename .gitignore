# Secrets — NEVER commit these
.env
.env.local
.env.*.local
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
.pytest_cache/

# ChromaDB — lives outside the repo, but safety belt in case anyone copies it in
chroma_db/
*.chroma
chroma_data/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
*.log
logs/

# Local config overrides
config/*.local.yaml

# Admin users (hashed passwords — never commit)
admin_users.json
config/admin_users.json

# Flask session storage
.flask_session/
flask_session/

# Local data directory (inventories, manifests, assets)
data/

# Admin UI audit log (append-only, local only)
audit.jsonl

# Session 12+: vision OCR cache (27 cached Gemini responses, regenerable)
data/image_ocr_cache/

# Session 12: eyeball-review HTML artifacts (regenerable via scripts/build_image_review.py)
data/image_samples/

# Session 11+: v2 ingest dumps (large JSON blobs, regenerable via --dump-json)
data/dumps/

# Session 13+: persistent skipped-files log (runtime artifact)
data/skipped_files_log.jsonl
