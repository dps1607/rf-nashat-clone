# Copy this file to .env and fill in the real values.
# .env is gitignored — your real secrets will never be committed.

# Anthropic API key for Claude generation
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI API key for query embeddings (text-embedding-3-large)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Admin UI password (LOCAL DEV ONLY — not used in Cloudflare Access mode)
# Pick a strong password. Will be required to access the admin UI locally.
ADMIN_PASSWORD=change-me-to-something-strong

# Flask session secret for the admin UI
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SESSION_SECRET=change-me-with-secrets-token-hex-32

# RAG server URL the admin UI calls for its inline test panel
RAG_SERVER_URL=http://localhost:5051

# Path to ChromaDB on disk
# Local dev: absolute path on your Mac (or leave unset to use ./chroma_db)
# Railway:    /data/chroma_db (mounted persistent volume)
CHROMA_DB_PATH=/Users/danielsmith/Claude - RF 2.0/chroma_db

# Which agent YAML to load by default
# Options: nashat_sales | nashat_coaching
DEFAULT_AGENT=nashat_sales

# Path to admin_users.json
# Local dev: leave unset (defaults to config/admin_users.json in the repo)
# Railway:    /data/admin_users.json (persistent volume)
ADMIN_USERS_PATH=

# Directory containing the agent YAML files (nashat_sales.yaml, nashat_coaching.yaml)
# Local dev: leave unset (defaults to config/ in the repo)
# Railway:    /data/config (persistent volume)
CONFIG_DIR=

# -----------------------------------------------------------------------------
# Phase 3.5 — Cloudflare Access + audit logging
# -----------------------------------------------------------------------------

# Enable Cloudflare Access mode. When true, the admin UI rejects local
# password logins and instead trusts the JWT that Cloudflare Access injects
# on every request. Set to true on Railway, leave unset/false for local dev.
CLOUDFLARE_ACCESS_ENABLED=false

# Cloudflare Access application "Audience" tag. You get this from the
# Cloudflare Zero Trust dashboard when you create the Access application:
#   Access → Applications → <your app> → Overview → Application Audience (AUD) Tag
# Required when CLOUDFLARE_ACCESS_ENABLED=true.
CLOUDFLARE_ACCESS_AUD=

# Cloudflare Access team domain, without protocol, without trailing slash.
# Format: <yourteam>.cloudflareaccess.com
# You can find it at: Zero Trust → Settings → Custom Pages → Team domain
# Required when CLOUDFLARE_ACCESS_ENABLED=true.
CLOUDFLARE_ACCESS_TEAM_DOMAIN=

# Path to the audit log file (JSON lines format, one event per line).
# Local dev: leave unset (defaults to ./audit.jsonl in the repo root, gitignored)
# Railway:    /data/audit.jsonl (persistent volume, survives redeploys)
AUDIT_LOG_PATH=
