# Copy this file to .env and fill in the real values.
# .env is gitignored — your real secrets will never be committed.

# Anthropic API key for Claude generation
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI API key for query embeddings (text-embedding-3-large)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Admin UI password (Phase 2 — not used yet)
# Pick a strong password. Will be required to access the admin UI.
ADMIN_PASSWORD=change-me-to-something-strong

# Path to ChromaDB on disk
# Local dev: absolute path on your Mac
# Railway:    /data/chroma_db (mounted persistent volume)
CHROMA_DB_PATH=/Users/danielsmith/Claude - RF 2.0/chroma_db

# Which agent YAML to load by default
# Options: nashat_sales | nashat_coaching
DEFAULT_AGENT=nashat_sales
